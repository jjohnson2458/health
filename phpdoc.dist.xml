<?xml version="1.0" encoding="UTF-8" ?>
<phpdocumentor
    configVersion="3"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://www.phpdoc.org/changes/3.0"
    xsi:noNamespaceSchemaLocation="https://docs.phpdoc.org/latest/phpdoc.xsd"
>
    <title>Claude Health API Documentation</title>

    <paths>
        <output>docs/phpdoc</output>
        <cache>/tmp/phpdoc-cache</cache>
    </paths>

    <version number="1.0.0">
        <api>
            <source dsn=".">
                <path>app</path>
                <path>core</path>
            </source>

            <output>.</output>

            <ignore hidden="true" symlinks="true">
                <path>app/Views</path>
                <path>app/Lang</path>
            </ignore>

            <extensions>
                <extension>php</extension>
            </extensions>

            <visibility>public</visibility>

            <default-package-name>ClaudeHealth</default-package-name>

            <markers>
                <marker>TODO</marker>
                <marker>FIXME</marker>
                <marker>HIPAA</marker>
            </markers>
        </api>
    </version>

    <template name="default" />
</phpdocumentor>
