APP_NAME=ClaudeHealth
APP_ENV=local
APP_URL=http://health.local
APP_KEY=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=claude_health
DB_USERNAME=root
DB_PASSWORD=

ENCRYPTION_KEY=

SESSION_LIFETIME=30
SESSION_SECURE=false

TWOFA_ENABLED=true
NEW_USER_REGISTRATION=true

# SMTP (production - direct send via PHPMailer)
# Leave SMTP_HOST blank to fall back to claude_messenger (local dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_REPLY_DOMAIN=

# Local dev fallback (claude_messenger)
MAIL_NOTIFY_SCRIPT=C:/xampp/htdocs/claude_messenger/notify.php
MAIL_FROM_NAME=ClaudeHealth
